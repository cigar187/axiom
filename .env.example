# ─────────────────────────────────────────────
# Axiom — Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# PostgreSQL — Google Cloud SQL (axiom_db database)
DATABASE_URL=postgresql+asyncpg://axiom_user:AxiomGTMVelo2026!@/axiom_db?host=/cloudsql/axiom-gtmvelo:us-central1:axiom-db

# For local development without Cloud SQL proxy:
# DATABASE_URL=postgresql+asyncpg://axiom_user:AxiomGTMVelo2026!@localhost:5432/axiom_db

# The Rundown API
RUNDOWN_API_KEY=25bf2c3f04a17935d5f26aeb03992fd579ed84b43b30ce102e680996aa8ce028
RUNDOWN_BASE_URL=https://therundown.io/api/v2

# Internal pipeline protection token
AXIOM_INTERNAL_TOKEN=4lhXHZsyl9_N3NaJlYou8byR_tTo_F-7sdK9q2GZ2QI

# App settings
APP_ENV=production
LOG_LEVEL=INFO
PORT=8080

# Google Cloud (used by deploy.sh)
GCLOUD_PROJECT=axiom-gtmvelo
GCLOUD_REGION=us-central1
CLOUD_RUN_SERVICE=axiom-engine
CLOUD_SQL_INSTANCE=axiom-gtmvelo:us-central1:axiom-db
